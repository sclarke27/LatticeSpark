{
  "name": "Hello World",
  "description": "Logs temperature sensor readings every 5 seconds",
  "version": "1.0.0",
  "enabled": true,
  "components": {
    "read": ["temperature_sensor"],
    "write": ["lcd_display"]
  },
  "triggers": {
    "interval": 5000,
    "onChange": ["temperature_sensor"]
  },
  "ui": {
    "page": true,
    "label": "Hello World"
  }
}
